import streamlit as st
import numpy as np
def render_chat_panel():
    st.markdown("## 💬 Dialogue – Medical AO")
    st.markdown("*Communicate with your Allostatic Prosthesis*")
    
    # Display message history
    for msg in st.session_state.messages:
        if msg["role"] == "user":
            st.markdown(f"<div class='chat-user'>{msg['content']}</div>", unsafe_allow_html=True)
        else:
            st.markdown(f"<div class='chat-ao'>🧠 {msg['content']}</div>", unsafe_allow_html=True)
    
    st.markdown("---")
    
    # Input
    user_input = st.text_input("Enter message", key="chat_input", placeholder="Ask about the current case...")
    
    col1, col2 = st.columns([1, 5])
    with col1:
        send = st.button("Send", use_container_width=True)
    with col2:
        clear = st.button("Clear History", use_container_width=True)
    
    if clear:
        st.session_state.messages = []
        st.rerun()
    
    if send and user_input.strip():
        st.session_state.messages.append({"role": "user", "content": user_input})
        
        # Generate contextual response
        response = generate_ao_response(user_input)
        st.session_state.messages.append({"role": "ao", "content": response})
        st.rerun()
def generate_ao_response(user_input: str) -> str:
    """Generate context-aware response from Medical AO."""
    
    user_lower = user_input.lower()
    
    # Context from current session
    if st.session_state.posterior is not None:
        module = st.session_state.module
        posterior = st.session_state.posterior
        policy = st.session_state.policy
        
        top_idx = int(np.argmax(posterior))
        top_dx = module.states[top_idx]
        top_prob = posterior[top_idx] * 100
        action = module.actions[policy]
        
        if any(word in user_lower for word in ["diagnosis", "result", "finding", "conclusion"]):
            return f"Based on active inference, the leading diagnosis is **{top_dx}** with {top_prob:.1f}% posterior probability. The recommended action is: {action}."
        
        elif any(word in user_lower for word in ["uncertain", "confidence", "sure"]):
            entropy = -np.sum(posterior * np.log2(posterior + 1e-10))
            max_entropy = np.log2(len(posterior))
            uncertainty = entropy / max_entropy * 100
            return f"Current diagnostic uncertainty is {uncertainty:.1f}% (normalized entropy). {'Consider additional investigations.' if uncertainty > 40 else 'Confidence is adequate for clinical action.'}"
        
        elif any(word in user_lower for word in ["action", "treat", "next", "recommend"]):
            return f"The expected free energy analysis recommends: **{action}**. This minimizes both epistemic uncertainty and pragmatic risk."
        
        elif any(word in user_lower for word in ["explain", "why", "how"]):
            return f"The active inference engine computed posterior beliefs by integrating prior probabilities with likelihood of observed findings. {top_dx} best explains the clinical pattern with minimal free energy."
        
        else:
            return f"I'm tracking the current case in **{module.name}**. The leading hypothesis is {top_dx} ({top_prob:.1f}%). How can I assist your reasoning?"
    
    else:
        if any(word in user_lower for word in ["hello", "hi", "start"]):
            return "Welcome. Navigate to **Case Input** to enter clinical findings, then return here for dialogue-based reasoning support."
        
        elif any(word in user_lower for word in ["help", "how", "what"]):
            return "I support clinical reasoning through active inference. Enter findings in **Case Input**, then ask me about diagnoses, uncertainty, or recommended actions."
        
        else:
            return "No active case loaded. Please run inference from **Case Input** first, then I can provide contextual analysis."

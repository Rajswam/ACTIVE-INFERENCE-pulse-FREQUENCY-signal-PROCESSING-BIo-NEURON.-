import numpy as np
from dataclasses import dataclass, field
@dataclass
class IzhikevichNeuron:
    """Izhikevich neuron model."""
    a: float = 0.02
    b: float = 0.2
    c: float = -65.0
    d: float = 8.0
    v: float = -65.0
    u: float = 0.0
    fired: bool = False
    
    def step(self, I: float, dt: float = 0.25) -> float:
        """Integrate one timestep."""
        if self.v >= 30.0:
            self.v = self.c
            self.u += self.d
            self.fired = True
        else:
            self.fired = False
        
        dv = 0.04 * self.v**2 + 5 * self.v + 140 - self.u + I
        du = self.a * (self.b * self.v - self.u)
        
        self.v += dt * dv
        self.u += dt * du
        
        return self.v
class CorticalColumn:
    """7-neuron cortical microcircuit generating multi-band oscillations."""
    
    def __init__(self, n_rs=2, n_fs=2, n_ib=1, n_lts=1, n_acp=1, n_sgi=1, n_tc=1):
        # Regular spiking (layer 2/3 pyramidal)
        self.rs = [IzhikevichNeuron(0.02, 0.2, -65, 8) for _ in range(n_rs)]
        # Fast spiking (GABAergic interneurons - gamma)
        self.fs = [IzhikevichNeuron(0.1, 0.2, -65, 2) for _ in range(n_fs)]
        # Intrinsically bursting (layer 5 pyramidal - beta)
        self.ib = [IzhikevichNeuron(0.02, 0.2, -55, 4) for _ in range(n_ib)]
        # Low-threshold spiking (slow inhibition)
        self.lts = [IzhikevichNeuron(0.02, 0.25, -65, 2) for _ in range(n_lts)]
        # Alpha-generating (posterior alpha rhythm)
        self.acp = [IzhikevichNeuron(0.01, 0.1, -65, 8) for _ in range(n_acp)]
        # Slow gamma interneuron (theta modulation)
        self.sgi = [IzhikevichNeuron(0.005, 0.2, -65, 0.5) for _ in range(n_sgi)]
        # Thalamocortical (delta rhythm)
        self.tc = [IzhikevichNeuron(0.02, 0.25, -65, 0.05) for _ in range(n_tc)]
        
        self.time = 0
    
    def step(self, sensory_input: float = 5.0, prediction_error: float = 2.0) -> list:
        """Step all neurons and return membrane potentials."""
        self.time += 1
        
        # Compute currents with oscillatory modulation
        I_rs = sensory_input + 3.0 * np.sin(self.time * 0.1)
        I_fs = prediction_error + 5.0 * np.sin(self.time * 0.3)
        I_ib = sensory_input * 0.8 + 2.0 * np.sin(self.time * 0.15)
        I_lts = 2.0 + 1.0 * np.sin(self.time * 0.05)
        I_acp = 3.0 + 2.0 * np.sin(self.time * 0.08)
        I_sgi = 1.5 + 1.0 * np.sin(self.time * 0.04)
        I_tc = 2.0 + 1.5 * np.sin(self.time * 0.02)
        
        # Step each neuron population
        v_rs = np.mean([n.step(I_rs) for n in self.rs])
        v_fs = np.mean([n.step(I_fs) for n in self.fs])
        v_ib = np.mean([n.step(I_ib) for n in self.ib])
        v_lts = np.mean([n.step(I_lts) for n in self.lts])
        v_acp = np.mean([n.step(I_acp) for n in self.acp])
        v_sgi = np.mean([n.step(I_sgi) for n in self.sgi])
        v_tc = np.mean([n.step(I_tc) for n in self.tc])
        
        return [v_rs, v_fs, v_ib, v_lts, v_acp, v_sgi, v_tc]

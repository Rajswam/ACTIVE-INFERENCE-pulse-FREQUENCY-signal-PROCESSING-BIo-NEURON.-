import streamlit as st
from modules import (
    EmergencyModule, NeoplasticModule, AutoimmuneModule,
    InfectiousModule, MentalHealthModule
)
def render_case_input():
    st.markdown("## 📋 Clinical Case Input")
    st.markdown("Select a specialist module and enter clinical findings.")
    
    modules = {
        "🚨 Emergency Medicine": EmergencyModule(),
        "🔬 Neoplastic": NeoplasticModule(),
        "🛡️ Autoimmune / GI": AutoimmuneModule(),
        "🦠 Infectious / Hepatology": InfectiousModule(),
        "🧠 Mental Health / Neurology": MentalHealthModule()
    }
    
    selected = st.selectbox("Select Clinical Module", list(modules.keys()))
    module = modules[selected]
    
    st.markdown("---")
    st.markdown("### Clinical Findings")
    st.markdown("*Check all that apply:*")
    
    cols = st.columns(2)
    checked = []
    
    for i, obs in enumerate(module.observations):
        with cols[i % 2]:
            val = st.checkbox(obs, key=f"obs_{i}")
            checked.append(1 if val else 0)
    
    st.markdown("---")
    
    if st.button("🔍 Run Active Inference", use_container_width=True):
        posterior, policy, free_energy = module.agent.step(checked)
        
        st.session_state.module = module
        st.session_state.posterior = posterior
        st.session_state.policy = policy
        st.session_state.observations = checked
        
        st.success("✅ Inference complete. Navigate to **Dashboard** or **25-Step Report**.")
        
        # Quick preview
        st.markdown("### Quick Results Preview")
        top_idx = posterior.argmax()
        st.metric(
            label="Most Likely Diagnosis",
            value=module.states[top_idx],
            delta=f"{posterior[top_idx]*100:.1f}% confidence"
        )

import numpy as np
from core.active_inference import ClinicalActiveInferenceAgent
class SpecialistModule:
    """Base class for clinical specialist modules."""
    
    def __init__(self, name: str, observations: list, states: list, 
                 actions: list, likelihood_matrix: np.ndarray):
        self.name = name
        self.observations = observations
        self.states = states
        self.actions = actions
        self.A = likelihood_matrix
        
        # Build agent
        n_states = len(states)
        n_actions = len(actions)
        
        B = np.eye(n_states)  # Identity transition (single-step inference)
        C = np.zeros(len(observations))  # Neutral preferences
        D = np.ones(n_states) / n_states  # Uniform prior
        policies = list(range(n_actions))
        
        self.agent = ClinicalActiveInferenceAgent(
            A=self.A,
            B=B,
            C=C,
            D=D,
            policies=policies,
            observations=observations,
            states=states,
            actions=actions
        )

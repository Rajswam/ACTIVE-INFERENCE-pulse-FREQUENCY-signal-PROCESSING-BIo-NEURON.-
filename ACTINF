import numpy as np
class CuriosityEngine:
    """Identifies epistemic actions to reduce diagnostic uncertainty."""
    
    def __init__(self, entropy_threshold: float = 0.4):
        self.entropy_threshold = entropy_threshold
    
    def compute_entropy(self, distribution: np.ndarray) -> float:
        """Compute Shannon entropy of a probability distribution."""
        p = np.array(distribution)
        p = p[p > 0]
        return -np.sum(p * np.log2(p + 1e-12))
    
    def identify_uncertainty(self, posterior: np.ndarray) -> float:
        """Return normalized entropy as uncertainty measure."""
        H = self.compute_entropy(posterior)
        H_max = np.log2(len(posterior) + 1e-12)
        return H / (H_max + 1e-12)
    
    def suggest(self, posterior: np.ndarray, observations: list, checked: list = None) -> list:
        """Generate natural-language suggestions for reducing uncertainty."""
        suggestions = []
        uncertainty = self.identify_uncertainty(posterior)
        
        if uncertainty > self.entropy_threshold:
            suggestions.append(
                f"⚠️ High diagnostic uncertainty ({uncertainty:.1%}). Consider additional investigations."
            )
        
        # Suggest unchecked high-value observations
        if checked is not None:
            unchecked = [obs for obs, c in zip(observations, checked) if c == 0]
            if unchecked and uncertainty > 0.3:
                suggestions.append(f"📋 Consider evaluating: {', '.join(unchecked[:3])}")
        
        if not suggestions:
            suggestions.append("✅ Diagnostic confidence is adequate.")
        
        return suggestions

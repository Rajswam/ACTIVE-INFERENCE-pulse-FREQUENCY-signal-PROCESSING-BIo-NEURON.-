import numpy as np
from scipy.special import softmax
class ClinicalActiveInferenceAgent:
    """Active inference agent for clinical decision-making."""
    
    def __init__(self, A, B, C, D, policies, observations, states, actions):
        """
        A: Likelihood matrix (observations x states)
        B: Transition matrix (states x states x actions)
        C: Preference vector (observations)
        D: Prior over initial states
        policies: List of action sequences
        """
        self.A = np.array(A)
        self.B = np.array(B) if B is not None else np.eye(len(states))
        self.C = np.array(C) if C is not None else np.zeros(len(observations))
        self.D = np.array(D) if D is not None else np.ones(len(states)) / len(states)
        self.policies = policies
        self.observations = observations
        self.states = states
        self.actions = actions
        self.qs = self.D.copy()
    
    def infer_states(self, obs_vector):
        """Variational inference: update beliefs given observations."""
        obs = np.array(obs_vector)
        
        # Log-likelihood of observations under each state
        log_likelihood = np.zeros(len(self.states))
        
        for s in range(len(self.states)):
            ll = 0
            for o in range(len(self.observations)):
                p = self.A[o, s]
                if obs[o] == 1:
                    ll += np.log(p + 1e-10)
                else:
                    ll += np.log(1 - p + 1e-10)
            log_likelihood[s] = ll
        
        # Posterior = prior * likelihood (in log space)
        log_posterior = np.log(self.D + 1e-10) + log_likelihood
        self.qs = softmax(log_posterior)
        
        return self.qs
    
    def compute_expected_free_energy(self):
        """Compute EFE for each policy/action."""
        efe = np.zeros(len(self.actions))
        
        for a in range(len(self.actions)):
            # Epistemic value: expected information gain
            epistemic = -np.sum(self.qs * np.log(self.qs + 1e-10))
            
            # Pragmatic value: expected preference satisfaction
            expected_obs = self.A @ self.qs
            pragmatic = -np.sum(expected_obs * self.C)
            
            efe[a] = epistemic + pragmatic
        
        return efe
    
    def select_policy(self):
        """Select action minimizing expected free energy."""
        efe = self.compute_expected_free_energy()
        policy_posterior = softmax(-efe)
        selected = np.argmax(policy_posterior)
        return selected, policy_posterior, efe
    
    def step(self, obs_vector):
        """Full inference step: perceive, infer, plan."""
        posterior = self.infer_states(obs_vector)
        policy, policy_posterior, efe = self.select_policy()
        
        free_energy = -np.sum(posterior * np.log(posterior + 1e-10))
        
        return posterior, policy, free_energy
